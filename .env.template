# ============================================================
# HApi Global Environment Variable Template
# Copy this file to .env and fill in your actual values
#   cp .env.template .env
# ============================================================

# ---------- General ----------
TIMEZONE=Asia/Shanghai

# ---------- Home Assistant Stack ----------
# Mosquitto MQTT credentials (change to your own)
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=change_me_to_a_strong_password

# Zigbee coordinator serial port (Windows: COM3, Linux: /dev/ttyUSB0 or /dev/ttyACM0, macOS: /dev/cu.usbserial-xxx)
ZIGBEE_COORDINATOR_PORT=/dev/ttyACM0
# Coordinator baud rate (CC2652/CC2531 usually 115200, ZBDongle-E 115200)
ZIGBEE_COORDINATOR_BAUDRATE=115200
# Zigbee channel (11-26). 15/20/25 avoid common WiFi channels 1/6/11 — see https://www.zigbee2mqtt.io/guide/configuration/
ZIGBEE_CHANNEL=15
# Zigbee network keys — GENERATE = random value will be created on first setup
# DO NOT change these after pairing devices, or you'll need to re-pair everything
ZIGBEE_NETWORK_KEY=GENERATE
ZIGBEE_PAN_ID=GENERATE
ZIGBEE_EXT_PAN_ID=GENERATE

# Node-RED web UI port
NODERED_PORT=1880

# Home Assistant HTTP — trusted reverse proxy CIDR (Docker bridge)
TRUSTED_PROXIES=172.16.0.0/12

# ---------- Voice Stack ----------
# openWakeWord Wyoming service port
OPENWAKEWORD_PORT=10400
# Vosk Wyoming service port
VOSK_PORT=10300
# Piper Wyoming service port
PIPER_PORT=10200

# Vosk language code (auto-downloaded on first run, or place pre-downloaded model under voice/vosk/data/)
# Model list: https://alphacephei.com/vosk/models
VOSK_LANGUAGE=zh

# Piper voice name (e.g. zh_CN-huayan, en_US-lessac)
PIPER_VOICE=zh_CN-huayan-medium

# ---------- Wyoming Satellite ----------
# Satellite display name (shown in HA)
SATELLITE_NAME=Living Room Satellite
# Port the satellite listens on for Wyoming protocol
SATELLITE_PORT=10700
# ALSA microphone device (use "arecord -L" to list options)
SATELLITE_MIC_DEVICE=plughw:1,0
# ALSA speaker device (use "aplay -L" to list options)
SATELLITE_SPEAKER_DEVICE=plughw:1,0

# ---------- Camera / Motion ----------
# Camera device (use "v4l2-ctl --list-devices" to find)
MOTION_CAMERA_DEVICE=/dev/video0
# Video resolution
MOTION_CAMERA_WIDTH=640
MOTION_CAMERA_HEIGHT=480
# Frames per second
MOTION_FRAMERATE=15
# Motion detection threshold (lower = more sensitive, range 1-1000000)
MOTION_THRESHOLD=1500
# Minimum frames with motion before triggering event
MOTION_MIN_FRAMES=2
# Minimum gap in seconds between separate events
MOTION_EVENT_GAP=5
# Directory for captured images and recordings
MOTION_TARGET_DIR=./camera/recordings
# MQTT broker for Home Assistant integration (use localhost if same host as mosquitto)
MOTION_MQTT_HOST=localhost
MOTION_MQTT_PORT=1883
# MQTT credentials (uncomment if authentication is enabled)
# MOTION_MQTT_USER=mqtt_user
# MOTION_MQTT_PASSWORD=change_me_to_a_strong_password
# Web control interface port
MOTION_WEBCONTROL_PORT=8081
# Live stream port
MOTION_STREAM_PORT=8082
