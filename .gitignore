# Dependencies
node_modules/

# Environment variables (contain sensitive info)
.env
homeassistant/.env
voice/.env

# Home Assistant — ignore directory contents but keep .gitkeep
homeassistant/config/*
!homeassistant/config/.gitkeep
homeassistant/mosquitto/data/*
!homeassistant/mosquitto/data/.gitkeep
homeassistant/mosquitto/log/*
!homeassistant/mosquitto/log/.gitkeep
homeassistant/zigbee2mqtt/data/*
!homeassistant/zigbee2mqtt/data/.gitkeep
!homeassistant/zigbee2mqtt/data/configuration.yaml.template
homeassistant/nodered/data/*
!homeassistant/nodered/data/.gitkeep
homeassistant/esphome-configs/*
!homeassistant/esphome-configs/.gitkeep

# Generated config files (produced by generate-config.js from .template)
homeassistant/mosquitto/config/mosquitto.conf

# ESPHome build artifacts
homeassistant/esphome-configs/.esphome/

# Model files (large) — keep .gitkeep
voice/openwakeword/custom/*
!voice/openwakeword/custom/.gitkeep
voice/vosk/data/*
!voice/vosk/data/.gitkeep
voice/piper/models/*
!voice/piper/models/.gitkeep

# System files
.DS_Store
Thumbs.db
*.log
